{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "spatial-audio-volume",
  "version": "0.1.0",
  "identifier": "com.fintechlab.spatial-audio-volume",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Spatial Audio Volume",
        "width": 760,
        "height": 620,
        "minWidth": 520,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
